{
  "vhosts": [{ "name": "dam" }],
  "users": [
    {
      "name": "dam_rabbit",
      "password": "rabbitpass",
      "tags": "administrator"
    }
  ],
  "permissions": [
    {
      "user": "dam_rabbit",
      "vhost": "dam",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "exchanges": [
    {
      "name": "dam.uploads",
      "vhost": "dam",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "dam.events",
      "vhost": "dam",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "dam.dead-letter",
      "vhost": "dam",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "asset-processing",
      "vhost": "dam",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "dam.dead-letter",
        "x-dead-letter-routing-key": "job.dead_lettered",
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "metadata-processing",
      "vhost": "dam",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "dam.dead-letter",
        "x-dead-letter-routing-key": "job.dead_lettered",
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "thumbnail-processing",
      "vhost": "dam",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "dam.dead-letter",
        "x-dead-letter-routing-key": "job.dead_lettered",
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "transcode-processing",
      "vhost": "dam",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "dam.dead-letter",
        "x-dead-letter-routing-key": "job.dead_lettered",
        "x-message-ttl": 86400000
      }
    },
    {
      "name": "asset-service-events",
      "vhost": "dam",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "dead-letter-queue",
      "vhost": "dam",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "dam.uploads",
      "vhost": "dam",
      "destination": "asset-processing",
      "destination_type": "queue",
      "routing_key": "asset.uploaded",
      "arguments": {}
    },
    {
      "source": "dam.uploads",
      "vhost": "dam",
      "destination": "metadata-processing",
      "destination_type": "queue",
      "routing_key": "asset.process.metadata",
      "arguments": {}
    },
    {
      "source": "dam.uploads",
      "vhost": "dam",
      "destination": "thumbnail-processing",
      "destination_type": "queue",
      "routing_key": "asset.process.thumbnail",
      "arguments": {}
