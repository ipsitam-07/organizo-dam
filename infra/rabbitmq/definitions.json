    {
      "source": "dam.uploads",
      "vhost": "dam",
      "destination": "transcode-processing",
      "destination_type": "queue",
      "routing_key": "asset.process.transcode",
      "arguments": {}
    },
    {
      "source": "dam.events",
      "vhost": "dam",
      "destination": "asset-service-events",
      "destination_type": "queue",
      "routing_key": "",
      "arguments": {}
    },
    {
      "source": "dam.dead-letter",
      "vhost": "dam",
      "destination": "dead-letter-queue",
      "destination_type": "queue",
      "routing_key": "#",
      "arguments": {}
    }
  ]
