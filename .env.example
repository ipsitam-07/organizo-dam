POSTGRES_PASSWORD=null

# Redis 
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# RabbitMQ 
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=dam_rabbit
RABBITMQ_PASSWORD=null
