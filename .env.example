AUTH_SERVICE_PORT=3001

# Upload Service 
UPLOAD_SERVICE_PORT=3002

# Asset Service 
ASSET_SERVICE_PORT=3003

# App (api) 
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:5173
