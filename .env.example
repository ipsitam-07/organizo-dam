MINIO_BUCKET_CHUNKS=chunks
MINIO_BUCKET_RENDITIONS=renditions

# TUS Server 
TUS_PORT=1080
TUS_MAX_SIZE=10737418240

# Auth Service 
JWT_SECRET=null
